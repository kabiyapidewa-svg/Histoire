# Variables d'environnement Histoire
# Copiez ce fichier vers .env (local) et renseignez les valeurs depuis Supabase.
# Dans Vercel : Project Settings > Environment Variables (mêmes noms, sans le fichier).

# Dashboard Supabase > Project Settings > API
# - "Project URL"  -> VITE_SUPABASE_URL
# - "anon public"  -> VITE_SUPABASE_ANON_KEY  (NE JAMAIS utiliser la "service_role" côté client)

VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE-CLE-ANON-PUBLIQUE

# Phase 4 — Notifications push natives (optionnel, seulement si tu actives les push)
# Génère les clés VAPID avec : npx web-push generate-vapid-keys
# Puis définis VAPID_PUBLIC_KEY et VAPID_PRIVATE_KEY dans les secrets Supabase
# (supabase secrets set VAPID_PUBLIC_KEY=xxx VAPID_PRIVATE_KEY=xxx VAPID_SUBJECT=mailto:toi@email.com)
VITE_VAPID_PUBLIC_KEY=
